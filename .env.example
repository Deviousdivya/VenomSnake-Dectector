# --- 🛡️ SECURITY SHIELD ---
# Use TLS 1.3 in production
# Configure Cloudflare/AWS WAF for L7 protection

# --- 🧪 ENVIRONMENT KEYS ---
GEMINI_API_KEY=your_key_here
NEWS_API_KEY=your_newsapi_org_key_here
JWT_SECRET=super_secret_shard_key

# --- 🚀 SCALABILITY ---
# Redis Configuration (Simulated via Node-Cache)
REDIS_URL=redis://cluster-endpoint:6379
REDIS_PASSWORD=

# Database Tiers
DATABASE_URL=postgresql://main-read-replica:5432/venomsnake

# --- 📊 MONITORING ---
# Prometheus/Grafana Endpoints
PROMETHEUS_METRICS_PATH=/api/metrics
GRAFANA_DASH_ID=VS-CL-04
